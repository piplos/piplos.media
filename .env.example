# Production / local API configuration. Copy to .env and adjust.
# Compose reads ${VAR} substitution from this file automatically.
#
# Host-side dev:
#   docker compose -f compose.dev.yml up -d db
#   ./scripts/migrate up
#   set -a && source .env && set +a && go run ./cmd/piplos

# --- Base domain (Traefik Host rules in compose.yml) ---
BASE_DOMAIN=piplos.media

# --- PostgreSQL (compose `db` service) ---
# Single source of truth: compose builds DATABASE_URL for `api` from these vars.
# Host-side dev builds localhost DSN from the same POSTGRES_* (see internal/config/dsn.go).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=piplos
POSTGRES_PORT=5433
POSTGRES_HOST=localhost
POSTGRES_SSLMODE=disable

# Optional explicit DSN (overrides POSTGRES_*). Production compose sets this for `db` host.
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/piplos?sslmode=disable

# --- API ---
PORT=3001
JWT_SECRET=dev-secret-change-me

# Ключ шифрования секретов в settings (AES-256-GCM), минимум 32 символа.
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY=dev-encryption-key-change-me-32b!
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_HOURS=168

# Comma-separated origins for CORS (admin + site dev servers).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Uploaded media (project case study images, etc.)
UPLOAD_DIR=data/uploads
PUBLIC_API_URL=http://localhost:3001

# Admin panel URL (lead notification emails link here).
ADMIN_URL=http://localhost:5174

# Initial admin (created on first start when users table is empty).
ADMIN_EMAIL=admin@piplos.media
ADMIN_PASSWORD=admin12345
